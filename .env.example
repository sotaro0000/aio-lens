# ── LLM プロバイダ設定（任意）─────────────────────────────
# 未設定でもヒューリスティック診断は完全に動作します。
# キーを設定すると、LLM による定性評価・改善提案・JSON-LD 自動生成が有効になります。

# 利用するプロバイダ: "openai" または "anthropic"
LLM_PROVIDER=openai

# OpenAI を使う場合
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude) を使う場合
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
